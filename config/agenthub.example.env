# AgentHub shared defaults. Copy to a local file and point AGENTHUB_ENV_FILE at it.
HOST=127.0.0.1
PORT=18080
AGENTHUB_PROFILE=demo
AGENTHUB_ENV=demo
AGENTHUB_DB_PATH=var\agenthub-demo.sqlite3
AGENTHUB_ARTIFACT_STORE_DIR=var\agenthub-demo-artifacts
AGENTHUB_STATIC_DEPLOY_DIR=var\agenthub-demo-static
AGENTHUB_PUBLIC_BASE_URL=http://127.0.0.1:18080
AGENTHUB_API_BASE_URL=http://127.0.0.1:18080
AGENTHUB_WEB_BASE_URL=http://127.0.0.1:3000
AGENTHUB_TEST_RUN_ID=local-demo

AGENTHUB_TURN_ROUTER_BACKEND=disabled
AGENTHUB_ENABLE_TEST_TURN_ROUTER_BACKEND=0
AGENTHUB_TURN_ROUTER_BASE_URL=
AGENTHUB_TURN_ROUTER_API_KEY=
AGENTHUB_TURN_ROUTER_MODEL=
AGENTHUB_TURN_ROUTER_RESPONSE_FORMAT=json_schema

AGENTHUB_CONTEXT_RECENT_MESSAGES=20
AGENTHUB_CONTEXT_MAX_MESSAGE_CHARS=4000
AGENTHUB_CONTEXT_MAX_TOTAL_CHARS=16000

AGENTHUB_MODEL_PROVIDER=custom_openai
AGENTHUB_CUSTOM_OPENAI_API_BASE=
AGENTHUB_CUSTOM_OPENAI_MODEL=
AGENTHUB_CUSTOM_OPENAI_API_KEY=

AGENTHUB_CODEX_EXECUTABLE=codex
AGENTHUB_CODEX_TIMEOUT_SECONDS=30
AGENTHUB_CODEX_IGNORE_USER_CONFIG=1
AGENTHUB_CODEX_DISABLE_FEATURES=plugins,apps
