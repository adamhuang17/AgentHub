# AgentHub Competition local env
# Copy to .env or set in your shell. Scripts do not fake success when values are missing.

HOST=127.0.0.1
PORT=8000
AGENTHUB_ENV=local
AGENTHUB_DB_PATH=var/agenthub.sqlite3
AGENTHUB_ARTIFACT_STORE_DIR=var/artifacts
AGENTHUB_STATIC_DEPLOY_DIR=var/static-deployments
AGENTHUB_PUBLIC_BASE_URL=http://127.0.0.1:8000
AGENTHUB_API_BASE_URL=http://127.0.0.1:8000
AGENTHUB_WEB_BASE_URL=http://127.0.0.1:3000

# OpenCode HTTP service used by the OpenCode adapter.
OPENCODE_API_BASE=http://127.0.0.1:4096

# Real Orchestrator planner. Leave disabled until you configure a real provider.
AGENTHUB_TURN_ROUTER_BACKEND=disabled
# AGENTHUB_TURN_ROUTER_BACKEND=openai_compatible
# AGENTHUB_TURN_ROUTER_BASE_URL=https://api.example.com/v1
# AGENTHUB_TURN_ROUTER_API_KEY=replace_me
# AGENTHUB_TURN_ROUTER_MODEL=replace_me

# Optional custom OpenAI-compatible Agent provider.
AGENTHUB_MODEL_PROVIDER=custom_openai
# AGENTHUB_CUSTOM_OPENAI_API_BASE=https://api.example.com/v1
# AGENTHUB_CUSTOM_OPENAI_API_KEY=replace_me
# AGENTHUB_CUSTOM_OPENAI_MODEL=replace_me

# Optional CLI adapters.
# AGENTHUB_CODEX_EXECUTABLE=codex
# AGENTHUB_CODEX_TIMEOUT_SECONDS=120
# AGENTHUB_CODEX_IGNORE_USER_CONFIG=1
# AGENTHUB_CODEX_DISABLE_FEATURES=plugins,apps
# AGENTHUB_CLAUDE_CODE_EXECUTABLE=claude
